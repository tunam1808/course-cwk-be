generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "mysql"
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String
  fullName    String?
  role        Role         @default(USER)
  status      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  progress    Progress[]
  userCourses UserCourse[]
  @@map("user")
}

model Course {
  id          Int            @id @default(autoincrement())
  title       String
  category    CourseCategory
  duration    Float?
  fileSize    Float?
  videoId     String?
  fileHash    String?
  uploadedAt  DateTime       @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  progress    Progress[]
  order       Int?
  userCourses UserCourse[]
  @@map("course")
}

model Progress {
  id        Int      @id @default(autoincrement())
  userId    Int
  courseId  Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@map("progress")
}

model UserCourse {
  id        Int      @id @default(autoincrement())
  userId    Int
  courseId  Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  grantedAt DateTime @default(now())

  @@unique([userId, courseId])
  @@map("user_course")
}

model Intro {
  id        Int      @id @default(autoincrement())
  slot      Int      @unique // ← thêm mới: 1, 2, hoặc 3
  videoId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("intro")
}
model CountdownSetting {
  id         Int       @id @default(1)
  active     Boolean   @default(false)
  visible    Boolean   @default(false)
  startTime  DateTime?
  durationMs BigInt?
  updatedAt  DateTime  @updatedAt

  @@map("countdown_setting") 
}

enum CourseCategory {
  CAPCUT_AI
  BAT_DONG_SAN
  MIEN_PHI
}

enum Role {
  ADMIN
  USER
}