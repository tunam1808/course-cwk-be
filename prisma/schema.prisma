generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "mysql"
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String
  fullName    String?
  role        Role         @default(USER)
  status      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  progress    Progress[]
  userCourses UserCourse[]
  @@map("user")
}

model Course {
  id          Int            @id @default(autoincrement())
  title       String
  category    CourseCategory
  duration    Float?
  fileSize    Float?
  videoId     String?
  fileHash    String?
  uploadedAt  DateTime       @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  progress    Progress[]
  order       Int?
  userCourses UserCourse[]
  @@map("course")
}

model Progress {
  id        Int      @id @default(autoincrement())
  userId    Int
  courseId  Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@map("progress")
}

model UserCourse {
  id        Int      @id @default(autoincrement())
  userId    Int
  courseId  Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  grantedAt DateTime @default(now())

  @@unique([userId, courseId])
  @@map("user_course")
}

model Intro {
  id        Int      @id @default(autoincrement())
  slot      Int      @unique // ← thêm mới: 1, 2, hoặc 3
  videoId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("intro")
}
model CountdownSetting {
  id         Int       @id @default(1)
  active     Boolean   @default(false)
  visible    Boolean   @default(false)
  startTime  DateTime?
  durationMs BigInt?
  updatedAt  DateTime  @updatedAt

  @@map("countdown_setting") 
}

model LuckySetting {
  id              Int     @id @default(1)
  showLuckyNumber Boolean @default(false)

  @@map("lucky_setting")
}

enum CourseCategory {
  CAPCUT_AI
  BAT_DONG_SAN
  MIEN_PHI
}

enum Role {
  ADMIN
  USER
}

// ── CẤP 1: Folder gốc ───────────────────────────────────────────────
model ResourceCategory {
  id           Int                  @id @default(autoincrement())
  name         String
  slug         String               @unique
  order        Int                  @default(0)
  isVip        Boolean              @default(true)  // true = chỉ VIP, false = tất cả user
  thumbnailKey String?              // path trên Bunny, vd: "covers/uuid.jpg"
  thumbnailUrl String?              @db.Text
  subFolders   ResourceSubFolder[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@map("resource_category")
}

// ── CẤP 2: Folder con ───────────────────────────────────────────────
model ResourceSubFolder {
  id         Int              @id @default(autoincrement())
  name       String
  slug       String
  order      Int              @default(0)
  categoryId Int
  category   ResourceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  files      ResourceFile[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@map("resource_sub_folder")
}

// ── CẤP 3: File tài nguyên ──────────────────────────────────────────
model ResourceFile {
  id            Int               @id @default(autoincrement())
  name          String
  description   String?
  subFolderId   Int
  subFolder     ResourceSubFolder @relation(fields: [subFolderId], references: [id], onDelete: Cascade)
  fileName      String            // tên file gốc khi upload
  fileKey       String            // full path trên Bunny, vd: "resources/nhac-nen/lo-fi/uuid.mp3"
  fileUrl       String            @db.Text
  fileSize      Int               // bytes
  mimeType      String
  fileType      ResourceFileType
  downloadCount Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([subFolderId])
  @@map("resource_file")
}

// ── Enum mới ─────────────────────────────────────────────────────────
enum ResourceFileType {
  MP3   // audio: mp3, wav, ogg, flac, aac
  MP4   // video: mp4, mov, avi, webm
  FONT  // font: ttf, otf, woff, woff2, zip
  OTHER
}